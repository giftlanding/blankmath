# Spacelift API access for local troubleshooting.
# Copy this to .env.local and fill in real values.

export SPACELIFT_API_KEY_ENDPOINT="https://YOUR_ACCOUNT.app.spacelift.io"
export SPACELIFT_API_KEY_ID="YOUR_API_KEY_ID"
export SPACELIFT_API_KEY_SECRET="YOUR_API_KEY_SECRET"
export SPACELIFT_STACK_ID="YOUR_STACK_ID"

# Optional local frontend development proxy.
# Vite reads these from ../.env.local when running inside frontend/.
# They let http://127.0.0.1:517x/api/generate proxy to the Lambda backend.
export LAMBDA_FUNCTION_URL="https://YOUR_LAMBDA_FUNCTION_URL/"
export INTERNAL_API_TOKEN="YOUR_INTERNAL_API_TOKEN"

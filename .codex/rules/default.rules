prefix_rule(
    pattern = ["gh", "run", "watch"],
    decision = "allow"
)
prefix_rule(
    pattern = ["ls"],
    decision = "allow"
)
prefix_rule(
    pattern = ["spacectl", "stack", "logs"],
    decision = "allow"
)
prefix_rule(
    pattern = ["/bin/zsh", "-lc", "source .env.local && spacectl stack task"],
    decision = "allow"
)

